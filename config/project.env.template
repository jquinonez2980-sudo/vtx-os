# VTX-OS environment variables
# Copy to C:\vtx-os\config\project.env and fill in values
# NEVER commit project.env to source control

GOOGLE_CLOUD_PROJECT=vtx-accounting-os-prod
GOOGLE_CLOUD_REGION=northamerica-northeast2
GOOGLE_APPLICATION_CREDENTIALS=C:\vtx-os\config\service-account.json

# ---------------------------------------------------------------------------
# ADK / Gemini (Phase 2)
# ---------------------------------------------------------------------------
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_LOCATION=northamerica-northeast1

# BigQuery
BQ_DATASET_ACCOUNTING=vtx_accounting
BQ_DATASET_TAX=vtx_tax
BQ_DATASET_AUDIT=vtx_audit

# Cloud Storage
GCS_BUCKET_EXPORTS=vtx-accounting-os-prod-vtx-exports
GCS_BUCKET_DOCUMENTS=vtx-accounting-os-prod-vtx-docs

# ---------------------------------------------------------------------------
# Secret Manager secret names (do NOT put actual values here)
# Set real values with:  gcloud secrets versions add <name> --data-file=-
# ---------------------------------------------------------------------------
SM_SECRET_SAGE50_ODBC_CONN=vtx-sage50-odbc-conn
SM_SECRET_SAGE50_COMPANY_PATH=vtx-sage50-company-path
SM_SECRET_CANTAX_API_KEY=vtx-cantax-api-key
SM_SECRET_GMAIL_OAUTH_CREDENTIALS=vtx-gmail-oauth-credentials

# ---------------------------------------------------------------------------
# Local dev overrides — bypass Secret Manager entirely (never commit values)
# ---------------------------------------------------------------------------
# VTX_SECRET_VTX_SAGE50_ODBC_CONN=DSN=LocalSage50;UID=admin;PWD=dev
# VTX_SECRET_VTX_SAGE50_COMPANY_PATH=C:\Sage\Simply\Data\MyCompany.sai
